# =====================================================
# SentinelAI — Environment Configuration Template
# Copy this file to `.env` and fill in real values.
# NEVER commit the actual `.env` file (it's gitignored).
# =====================================================

# ----- App -----
ENVIRONMENT=development
APP_NAME=SentinelAI
API_PREFIX=/api/v1

# ----- Database -----
# SQLite for local/dev. Swap for a Postgres URL in production:
# postgresql://user:password@host:5432/sentinelai
DATABASE_URL=sqlite:///./app/data/sentinelai.db

# ----- Security / JWT Auth -----
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-random-hex-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----- File Encryption (Fernet symmetric key) -----
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# ----- Automated Backup -----
BACKUP_DIR=./backups
BACKUP_INTERVAL_MINUTES=30

# ----- Log Monitoring -----
LOG_WATCH_DIR=./logs
SCAN_INTERVAL_SECONDS=15

# ----- CORS (frontend origin) -----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173